// Prisma Schema — SnapPrice (Prisma v7)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  name      String?
  password  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  analyses  Analysis[]
}

model Analysis {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  imageUrl     String?
  itemName     String
  estimatedMin Float
  estimatedMax Float
  avgPrice     Float
  confidence   Float
  platforms    Json
  tips         String[]
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}
