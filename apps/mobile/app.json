{
  "expo": {
    "name": "SnapPrice",
    "slug": "snap-price",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "snapprice",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F0F0F"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.andredevfront.snapprice",
      "infoPlist": {
        "NSCameraUsageDescription": "O SnapPrice usa a câmera para fotografar itens e estimar seus preços de mercado."
      }
    },
    "android": {
      "package": "com.andredevfront.snapprice",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0F0F0F"
      },
      "permissions": [
        "android.permission.CAMERA"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "O SnapPrice usa a câmera para fotografar itens e estimar seus preços de mercado."
        }
      ],
      "expo-asset",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "120fcb0c-6c5c-4ba1-8f43-48ac2aa4194c"
      }
    }
  }
}
